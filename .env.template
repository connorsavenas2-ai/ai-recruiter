# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── BLAND.AI (Voice Calls) ───────────────────────────────────────────
# Get from: https://app.bland.ai/dashboard → API Keys
BLAND_API_KEY=sk_...
# Your cloned voice ID (create at app.bland.ai → Voices → Clone Voice)
BLAND_VOICE_ID=

# ── AIRTABLE (Candidate ATS) ─────────────────────────────────────────
# Get from: https://airtable.com/create/tokens
AIRTABLE_API_KEY=pat...
# Create a base called "AI Recruiter ATS" — copy the base ID from the URL
# URL looks like: airtable.com/appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=app...
# Table names (create these in your Airtable base)
AIRTABLE_CANDIDATES_TABLE=Candidates
AIRTABLE_JOBS_TABLE=Jobs
AIRTABLE_CALLS_TABLE=Call_Logs

# ── GOOGLE CALENDAR ──────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console:
# console.cloud.google.com → APIs → Google Calendar API → Credentials → OAuth 2.0
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_ID=primary

